      "recommended_tests": [
        "test/test_api_pipeline.py",
        "test/test_grok_web_app.py",
        "test/test_grok_batch_app.py",
        "test/test_sequence_optimizer_app.py"
      ]
    },
    {
      "id": "grok_runtime",
      "description": "Изменение браузерной автоматизации Grok, таймаутов или flow подготовки background/video.",
      "must_touch": [
        "api/grok_web.py",
        "main_grok_web.py"
      ],
      "must_review": [
        "main_grok_batch.py",
        "main_full_pipeline.py",
        "utils/project_delivery.py"
      ],
      "minimum_checks": [
        "single-stage run",
        "batch run",
        "background-only run",
        "no-submit mode"
      ],
      "recommended_tests": [
        "test/test_grok_web_app.py",
        "test/test_grok_batch_app.py",
        "test/test_full_pipeline.py",
        "test/test_project_delivery.py"
      ]
    },
    {
      "id": "delivery_cleanup",
      "description": "Изменение правил синхронизации, очистки, архивации или error-handling.",
      "must_touch": [
        "utils/project_delivery.py"
      ],
      "must_review": [
        "main_grok_batch.py",
        "main_full_pipeline.py",
        "utils/artifact_cleanup.py",
